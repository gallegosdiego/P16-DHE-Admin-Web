# ------------------------------------------
# Danhei Express - .env de Produccion
# Copiar como .env en el servidor y llenar
# ------------------------------------------

APP_NAME="Danhei Express"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.danheiexpress.com

# Base de datos
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=danheiex_production
DB_USERNAME=danheiex_user
DB_PASSWORD=

# Auth
SANCTUM_STATEFUL_DOMAINS=admin.danheiexpress.com,portal.danheiexpress.com,danheiexpress.com
SESSION_DOMAIN=.danheiexpress.com

# Cache y sesion
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# WhatsApp / Meta
META_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_INBOUND_ENABLED=false
WHATSAPP_OUTBOUND_ENABLED=false
WHATSAPP_ADMIN_UI_ENABLED=false
FLOW_PRIVATE_KEY=
FLOW_PRIVATE_KEY_PASSWORD=
WHATSAPP_PICKUP_REQUIRED_PERMISSION=CREATE_PICKUP
WHATSAPP_PICKUP_DEFAULT_CITY=Bogota

# Superadmin (para ProductionSeeder)
MASTER_EMAIL=admin@danheiexpress.com
MASTER_NAME="Angel Danhei"
MASTER_PASSWORD=

# Logs
LOG_CHANNEL=daily
LOG_LEVEL=warning

# CORS
CORS_ALLOWED_ORIGINS=https://admin.danheiexpress.com,https://portal.danheiexpress.com,https://danheiexpress.com
