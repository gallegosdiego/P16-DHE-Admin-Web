APP_ENV=staging
APP_DEBUG=false

META_APP_ID=
META_APP_SECRET=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_API_BASE_URL=https://graph.facebook.com
WHATSAPP_CLOUD_API_VERSION=v23.0
WHATSAPP_INBOUND_ENABLED=false
WHATSAPP_OUTBOUND_ENABLED=false
WHATSAPP_ADMIN_UI_ENABLED=false

WHATSAPP_PICKUP_REQUIRED_PERMISSION=CREATE_PICKUP
WHATSAPP_PICKUP_DEFAULT_CITY=Bogota

# Recomendado:
# - usar credenciales separadas de produccion
# - no reutilizar el mismo verify token entre entornos
# - mantener este archivo solo como referencia, no con secretos reales
# - habilitar inbound, outbound y admin UI solo cuando Meta autorice el ambiente
